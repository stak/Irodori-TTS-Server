# Server
IRODORI_HOST=0.0.0.0
IRODORI_PORT=8088
# Docker build backend: cu128, rocm, or cpu.
IRODORI_TTS_BACKEND=cu128
# Optional. When set, clients must send Authorization: Bearer <value>.
# IRODORI_API_KEY=change-me

# Model
IRODORI_HF_CHECKPOINT=Aratako/Irodori-TTS-500M-v3
# IRODORI_CHECKPOINT=/models/model.safetensors
IRODORI_CODEC_REPO=Aratako/Semantic-DACVAE-Japanese-32dim
IRODORI_MODEL_NAME=irodori-tts
IRODORI_MODEL_DEVICE=auto
IRODORI_CODEC_DEVICE=auto
IRODORI_MODEL_PRECISION=fp32
IRODORI_CODEC_PRECISION=fp32
# Keep compile disabled when using per-request irodori.lora_adapter.
IRODORI_COMPILE_MODEL=false
IRODORI_COMPILE_DYNAMIC=false
IRODORI_PRELOAD=false
# Capture CUDA graphs during startup so the first request is already fast.
# Implies loading the model at startup. CUDA only; a no-op elsewhere.
IRODORI_PREWARM=false
# Upper bound of the audio duration range covered by prewarmed graphs.
# 15s is roughly 1-1.5 GiB of extra VRAM (see performance docs).
IRODORI_PREWARM_MAX_SECONDS=15
# Optional. Prewarm with this LoRA adapter loaded so requests using it take
# the fast path immediately. POST /v1/admin/prewarm can re-prewarm later.
# IRODORI_PREWARM_LORA_ADAPTER=/models/adapters/speaker-a
IRODORI_MODEL_LOAD_TIMEOUT=300
IRODORI_MAX_CONCURRENT_SYNTHESIS=1
IRODORI_SYNTHESIS_WAIT_TIMEOUT=300

# Irodori-TTS performance fork (read directly by the irodori-tts library).
# Defaults shown. See https://github.com/stak/Irodori-TTS/blob/main/docs/performance.md
# 1 disables TF32 matmul (exact fp32, slower).
IRODORI_DISABLE_TF32=0
# 1 keeps LoRA adapters unmerged (upstream behavior).
IRODORI_DISABLE_LORA_MERGE=0
# 1 disables CUDA graph capture/replay entirely.
IRODORI_DISABLE_CUDA_GRAPH=0
# 1 keeps condition encoding + duration prediction eager.
IRODORI_DISABLE_DURATION_GRAPH=0
# 1 keeps the codec decoder in fp32 (exact decode, ~2x slower).
IRODORI_DISABLE_FP16_DECODE=0
# Comma-separated text-length buckets (tokens); 0 or empty disables.
IRODORI_TEXT_BUCKETS=64
# 1 runs the DiT through torch.compile (needs Triton: Linux/WSL2 + C compiler).
IRODORI_COMPILE=0
# Latent-length bucket size in patched steps; 1 disables padding.
IRODORI_CUDA_GRAPH_BUCKET=16
# Max cached CUDA graph entries.
IRODORI_CUDA_GRAPH_CACHE=64

# Voices
IRODORI_VOICES_DIR=voices
# IRODORI_DEFAULT_VOICE=sample
IRODORI_ALLOW_NO_REF_VOICE=true

# Defaults for /v1/audio/speech
IRODORI_DEFAULT_RESPONSE_FORMAT=wav
# MP3 encoder settings (soundfile/libsndfile path).
# Bitrate mode: VARIABLE (LAME VBR), AVERAGE, or CONSTANT.
IRODORI_MP3_BITRATE_MODE=VARIABLE
# 0.0 (highest quality) to just under 1.0. For VARIABLE this is the LAME -V
# quality (0.0 = -V0, ~160 kbps mono); for CONSTANT it selects the bitrate
# (0.0 = 320 kbps).
IRODORI_MP3_COMPRESSION_LEVEL=0.0
IRODORI_DEFAULT_NUM_STEPS=40
IRODORI_DEFAULT_T_SCHEDULE_MODE=linear
IRODORI_DEFAULT_SWAY_COEFF=-1.0
IRODORI_DEFAULT_DURATION_SCALE=1.0
IRODORI_DEFAULT_CFG_SCALE_TEXT=3.0
IRODORI_DEFAULT_CFG_SCALE_SPEAKER=5.0
IRODORI_DEFAULT_CFG_GUIDANCE_MODE=independent
IRODORI_DEFAULT_CHUNKING_ENABLED=true
IRODORI_DEFAULT_CHUNK_MIN_CHARS=80
# IRODORI_DEFAULT_FIRST_SENTENCE_CHUNK_MIN_CHARS=1
# Swap LoRA adapter weights in place so cached CUDA graphs survive switches.
IRODORI_DEFAULT_LORA_HOT_SWAP=false
# Embed the SilentCipher AI-generation watermark (~15 ms per request).
IRODORI_DEFAULT_APPLY_WATERMARK=true
